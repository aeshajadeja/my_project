<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Faculty Desk"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/facultyWelcomeTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome, Professor"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/logoutBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/error"
                android:padding="12dp"
                android:contentDescription="Logout"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/facultyProfileCard"
                android:layout_width="54dp"
                android:layout_height="54dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/softBlue"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/facultyProfileIconView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:scaleType="centerCrop"
                    app:tint="@color/primaryColor"
                    android:padding="12dp"
                    android:contentDescription="Profile"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="40dp">

            <!-- Hero Stats Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/primaryColor"
                android:layout_marginBottom="28dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="28dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Overview"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 Classes Pending"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="4dp"/>
                    
                    <View 
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:background="@color/accentColor"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Management Tools"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/textColorPrimary"
                android:textSize="20sp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Mark Attendance -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultyAttendanceCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/softBlue">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_agenda" app:tint="@color/primaryColor" android:contentDescription="Attendance"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Attendance" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Assignments -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultyAssignmentsCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/pastelPurple">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_edit" app:tint="@color/primaryDarkColor" android:contentDescription="Assignments"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Assignments" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Exams & Results -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultyExamResultCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/lightTeal">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/accentColor" android:contentDescription="Results"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Exam Results" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Schedule -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultyScheduleCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/softBlue">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_today" app:tint="@color/primaryLightColor" android:contentDescription="Schedule"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Timetable" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Syllabus -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultySyllabusCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/pastelPurple">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_save" app:tint="@color/primaryDarkColor" android:contentDescription="Syllabus"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Syllabus" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Announcements -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultyNoticeCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/lightTeal">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_dialog_info" app:tint="@color/accentColor" android:contentDescription="Notices"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notices" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Messages -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/facultyChatCard"
                    style="@style/CardStyle"
                    android:layout_columnWeight="1"
                    app:cardBackgroundColor="@color/softBlue">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/stat_notify_chat" app:tint="@color/success" android:contentDescription="Messages"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Messages" android:fontFamily="sans-serif-medium" android:textSize="13sp" android:layout_marginTop="12dp" android:textColor="@color/textColorPrimary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>