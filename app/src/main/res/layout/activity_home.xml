<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/welcomeText"
                android:text="Hi, Student 👋"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"/>

            <TextView
                android:id="@+id/dateText"
                android:text="Today"
                android:textSize="14sp"
                android:textColor="@color/textSecondary"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/headerLogoutBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/error"
            android:contentDescription="Logout"/>

    </LinearLayout>

    <!-- CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CONTEXT CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/cardBackground"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:text="Select Semester"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"/>

                    <Spinner
                        android:id="@+id/homeSemesterSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/spinner_bg"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- WARNING -->
            <TextView
                android:id="@+id/lockNoteTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Select semester to unlock features"
                android:textColor="@color/error"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/spinner_bg"/>

            <!-- GRID DASHBOARD -->
            <GridLayout
                android:id="@+id/homeContentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2">

                <!-- CARD TEMPLATE -->
                <!-- Attendance -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/attendanceCard"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/cardBackground"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/primary"/>

                        <TextView
                            android:text="Attendance"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Notices -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/notifyCard"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/cardBackground"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@android:drawable/ic_popup_reminder"
                            app:tint="@color/accent"/>

                        <TextView
                            android:text="Notices"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Assignments -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/assignmentsCard"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/cardBackground"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="@color/accent"/>

                        <TextView
                            android:text="Assignments"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Results -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/resultsCard"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/cardBackground"
                    android:clickable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="@color/primary"/>

                        <TextView
                            android:text="Results"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>