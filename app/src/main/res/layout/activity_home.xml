<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgColor">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/welcomeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hi, Student!"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready for today's classes?"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/headerLogoutBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/error"
                android:padding="12dp"
                android:contentDescription="Logout"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileCard"
                android:layout_width="54dp"
                android:layout_height="54dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/pastelPurple"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/profileIconView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:scaleType="centerCrop"
                    app:tint="@color/primaryColor"
                    android:padding="12dp"
                    android:contentDescription="Profile"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="40dp">

            <!-- Selection Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/peachCream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Academic Profile"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primaryDarkColor"
                        android:textSize="16sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <Spinner
                            android:id="@+id/homeYearSpinner"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/spinner_bg"
                            android:layout_marginEnd="6dp"/>

                        <Spinner
                            android:id="@+id/homeSemesterSpinner"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/spinner_bg"
                            android:layout_marginStart="6dp"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/lockNoteTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please select your Batch and Semester to unlock all features."
                android:textColor="@color/primaryColor"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:padding="32dp"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:id="@+id/homeContentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Feature Hero Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/quizCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="28dp"
                    app:cardBackgroundColor="@color/royalPurple"
                    android:layout_marginBottom="28dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="28dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Daily Quiz Challenge"
                                android:textColor="#CCFFFFFF"
                                android:textSize="14sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Test Your Skills"
                                android:textColor="@color/white"
                                android:textSize="22sp"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#33FFFFFF">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/btn_star_big_on"
                                app:tint="@color/white"
                                android:padding="14dp"
                                android:contentDescription="Quiz"/>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Campus Services"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="20sp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="4dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false">

                    <!-- Grid Item 1: Attendance -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/attendanceCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/softBlue">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_agenda"
                                app:tint="@color/primaryColor"
                                android:contentDescription="Attendance"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Attendance"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 2: Schedule -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/timetableCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/pastelPurple">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_today"
                                app:tint="@color/primaryDarkColor"
                                android:contentDescription="Schedule"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Timetable"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 3: Assignments -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/assignmentsCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/lightTeal">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_edit"
                                app:tint="@color/vibrantTeal"
                                android:contentDescription="Assignments"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Assignments"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 4: Notices -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/notifyCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/peachCream">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_popup_reminder"
                                app:tint="@color/sunsetOrange"
                                android:contentDescription="Notices"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notices"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 5: Messages -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/chatCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/pastelPurple">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/stat_notify_chat"
                                app:tint="@color/mintGreen"
                                android:contentDescription="Messages"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Messages"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 6: Syllabus -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/studentSyllabusCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/lightTeal">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_save"
                                app:tint="@color/royalPurple"
                                android:contentDescription="Syllabus"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Syllabus"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 7: Results -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/resultsCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/softBlue">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_search"
                                app:tint="@color/primaryColor"
                                android:contentDescription="Results"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Results"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 8: Library -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/libraryCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/pastelPurple">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="@color/limePop"
                                android:contentDescription="Library"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Library"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 9: Fees -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/feesCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/lightTeal">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_send"
                                app:tint="@color/goldenYellow"
                                android:contentDescription="Fees"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fees"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Grid Item 10: Events -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/eventsCard"
                        style="@style/CardStyle"
                        android:layout_columnWeight="1"
                        app:cardBackgroundColor="@color/softBlue">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="24dp"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                app:tint="@color/secondaryColor"
                                android:contentDescription="Events"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Events"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/textColorPrimary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>