<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Decorative Soft Circles for Modern Feel -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/circular_bg"
        android:backgroundTint="@color/softBlue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:translationX="150dp"
        android:translationY="-150dp"/>

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/circular_bg"
        android:backgroundTint="@color/pastelPurple"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:translationX="-125dp"
        android:translationY="125dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logoContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/softBlue">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_campus_logo"
                android:padding="24dp"
                android:contentDescription="App Logo"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SmartCampus"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/primaryColor"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Digital Education Hub"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/textColorSecondary"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <ProgressBar
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/primaryColor"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="80dp"
        style="?android:attr/progressBarStyleLarge"/>

</androidx.constraintlayout.widget.ConstraintLayout>
